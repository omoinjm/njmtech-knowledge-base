{
  "name": "blob-cron",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/blob-cron/src",
  "targets": {
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "poetry run python main.py",
        "cwd": "apps/blob-cron",
        "envFile": "environments/blob-cron.env"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pytest",
        "cwd": "apps/blob-cron",
        "envFile": "environments/blob-cron.env"
      }
    },
    "worker-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev",
        "cwd": "apps/blob-cron"
      }
    },
    "worker-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run deploy",
        "cwd": "apps/blob-cron"
      }
    }
  }
}
