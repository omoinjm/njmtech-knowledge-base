{
  "name": "upload-blob",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/upload-blob/api",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uvicorn api.main:app --reload",
        "cwd": "apps/upload-blob",
        "envFile": "environments/upload-blob.env"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pytest",
        "cwd": "apps/upload-blob"
      }
    }
  }
}
